# Traefik hostname — must match DNS A/AAAA record AND the URL in your browser
TRAEFIK_HOST=guide.moln.nasto.ovh

# Must match certificatesResolvers.<name> in your Traefik static config (often letsencrypt or le)
CERT_RESOLVER=letsencrypt

# OIDC authentication (PocketId). Leave OIDC_ENABLED=false for local dev without login.
OIDC_ENABLED=true
OIDC_ISSUER=https://auth.moln.nasto.ovh
OIDC_CLIENT_ID=client-id
OIDC_CLIENT_SECRET=client-secret
OIDC_REDIRECT_URI=https://guide.moln.nasto.ovh/auth/callback
OIDC_BASE_URL=https://guide.moln.nasto.ovh
SESSION_SECRET=session-secret
OIDC_SCOPES=openid email profile

# LLM robot navigation service (standalone — talks to robot only via HTTP/WebSocket API)

# Simulated robot (logs HTTP calls, no hardware)
ROBOT_SIMULATED=true
PORT=8001

# Multi-robot (UI select: Dog / Loomo). OpenAPI specs in configs/
# ROBOT_DEFAULT=loomo          # loomo | go1
# ROBOT_LOOMO_URL=https://loomo.cphs.mylab.th-luebeck.de
# ROBOT_GO1_URL=https://go1.cphs.mylab.th-luebeck.de
# Spec files: configs/loomo_openapi.json, configs/robot_openapi.json (Go1 dog)

# Legacy single-robot fallback:
# ROBOT_BASE_URL=https://loomo.cphs.mylab.th-luebeck.de
# ROBOT_API=auto   # auto | go1 | loomo

# Google Maps GPS routing
# GOOGLE_MAPS_API_KEY=your-google-maps-key

# mylab OpenAI-compatible API (openai-completions)
NAV_API_BASE_URL=https://models.mylab.th-luebeck.dev/v1
NAV_API_KEY=none
NAV_LLM_MODEL=chat-vl-large

# Other mylab chat models:
#   chat-vl-large   — Qwen 3.5 (397B)  [default]
#   chat-vl-xlarge  — Mistral Large (675B)
#   gpt-oss-120b    — GPT OSS 120B XL
#   chat-vl-fast    — Gemma 4 31B

# Fake GPS progress along the route (no physical movement required)
# NAVIGATION_SIMULATE_PROGRESS=true

# Motion mode: distance-based (default) or live phone GPS (experimental)
# NAVIGATION_USE_LIVE_GPS=false

# Distance-based motion tuning:
# NAV_ORIGIN_HEADING_DEG=300   # compass ° robot faces at start (0=north, 90=east)
# NAV_HEADING_TOLERANCE_DEG=15 # skip align turn if within this many degrees
# NAV_MIN_FORWARD_M=3
# NAV_TURN_DURATION_SEC=3.0
# NAV_UTURN_DURATION_SEC=6.0
# GPS_SPEED_KMH=3          # forward speed (3 km/h)

# Phone GPS stream (only when NAVIGATION_USE_LIVE_GPS=true — see ../phone_gps/)
# GPS_STREAM_URL=http://localhost:8080
# GPS_TOKEN=
# GPS_ACCESS_PASSWORD=
# GPS_MAX_AGE_SEC=20
# GPS_ARRIVAL_RADIUS_M=10
# GPS_TURN_TOLERANCE_DEG=30
# GPS_STEP_TIMEOUT_SEC=120
# GPS_ANGULAR_SPEED=0.55

# Audio pipeline tests (Loomo POST /api/cmd speak — no TTS):
#   python launch.py --test speak --text "Hello"
#   python launch.py --test listen --duration 5
#   python launch.py --test echo --duration 5
# Motion (short in-room nudges, capped speed/duration):
#   python launch.py --test move --direction forward --move-duration 1.2
#   python launch.py --test patrol
#   python launch.py --test stop
# Or open http://localhost:8001/test
# NAV_STT_MODEL=whisper-3-large
# NAV_STT_LANGUAGE=en

# Siri-style wake phrase on robot mic ("Hi Loomo, …" → LLM). Requires ROBOT_SIMULATED=false.
# WAKE_WORD_AUTO_START=true
# WAKE_CAPTURE_DURATION_SEC=5.0
